# Enrichment Workbench — copy to .env and adjust.
# All host ports bind 127.0.0.1 only.

# Workbench's own Postgres (PostGIS) — mirrors, runs, sync state
WB_POSTGRES_DB=enrich
WB_POSTGRES_USER=enrich
WB_POSTGRES_PASSWORD=enrich
WB_POSTGRES_HOST_PORT=15432

# Oxigraph (facts as RDF quads)
OXIGRAPH_HOST_PORT=7878

# Workbench API / web
ENRICH_API_HOST_PORT=8070
ENRICH_WEB_HOST_PORT=8071

# Source-of-truth Hillview DB the mirror-sync READS (never writes).
# Default targets the local dev stack over the shared docker network
# (api container joins hillview_network; "postgres" resolves there).
# Later: point at a prod read-only role over a tunnel — one variable.
HILLVIEW_DB_URL=postgresql+asyncpg://hillview:hillview@postgres:5432/hillview

# Allow raw SPARQL UPDATE via POST /api/sparql (full-quads fun escape hatch)
ENRICH_ALLOW_RAW_UPDATE=0
