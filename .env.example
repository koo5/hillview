
# Database Configuration (required — compose will refuse to start without these)
POSTGRES_DB=hillview
POSTGRES_USER=hillview
POSTGRES_PASSWORD=hillview
POSTGRES_HOST_PORT=5432
# DB_HOST=localhost  # uncomment for dev (host networking); defaults to 'postgres' (bridge mode)


# API Configuration (required — compose will refuse to start without SECRET_KEY)
API_PORT=8055
SECRET_KEY=ssssseeeeeeccccccccrrrrrreeeeeeettttttttt


GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8212/api/auth/oauth-callback


TEST_USERS=true
DEV_MODE=true
NO_LIMITS=true
DEBUG_ENDPOINTS=true
WORKER_URL=http://localhost:8056
PICS_URL=http://localhost:9999/

# Storage pools (optional). FILE_POOLS is a JSON array describing every location
# photos may live in. New local uploads are written to the first "files" pool;
# the remaining entries let existing photos stay resolvable for deletion by URL.
# When FILE_POOLS is unset, the registry is synthesised from PICS_URL/PICS_DIR
# (plus the CDN env below, if set), so existing deployments need no change.
# To add a second disk: serve it (e.g. via Caddy) and prepend it as a files pool.
#   files pool: {"type":"files","url":<public base url>,"path":<filesystem dir>}
#   cdn pool:   {"type":"cdn","url":<public base url>,"bucket":<name>,
#                "endpoint":<s3 endpoint>,"secrets_file":<path>,
#                "addressing_style":"virtual"|"path"}
# cdn credentials come from the secrets_file (JSON: {"access_key_id":"...",
# "secret_access_key":"..."}); use addressing_style "path" for self-hosted S3.
# FILE_POOLS=[{"url":"https://pics2.hillview.cz/","path":"/app/pics2"},{"url":"https://pics.hillview.cz/","path":"/app/pics"}]


# Umami Analytics
UMAMI_APP_SECRET=replace-me-with-a-real-secret
UMAMI_PORT=3333

# ImageMagick Resource Limits (sized for 300000x30000 panorama processing)
MAGICK_MEMORY_LIMIT=8GiB
MAGICK_MAP_LIMIT=16GiB
MAGICK_DISK_LIMIT=64GiB
MAGICK_WIDTH_LIMIT=500000
MAGICK_HEIGHT_LIMIT=500000
MAGICK_AREA_LIMIT=12GP

