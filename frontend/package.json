{
  "name": "hillview",
  "version": "0.0.2",
  "devDependencies": {
    "@sentry/sveltekit": "^10",
    "@sveltejs/adapter-auto": "^4.0.0",
    "@sveltejs/adapter-node": "^5.4.0",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/cli": "^2.6.2",
    "@tauri-apps/plugin-deep-link": "^2.4.1",
    "@tauri-apps/plugin-fs": "^2.4.2",
    "@tauri-apps/plugin-geolocation": "^2.3.0",
    "@tauri-apps/plugin-opener": "~2",
    "@tauri-apps/plugin-os": "^2.3.0",
    "@tauri-apps/plugin-shell": "~2",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/svelte": "^5.2.8",
    "@types/crypto-js": "^4.2.2",
    "@types/leaflet": "^1.9.19",
    "@types/qrcode": "^1.5.6",
    "@vitest/ui": "^4.1.4",
    "angles": "^0.3.0",
    "crypto-js": "^4.2.0",
    "dexie": "^4.0.11",
    "happy-dom": "^20.8.9",
    "leaflet": "^1.9.4",
    "leaflet-providers": "^2.0.0",
    "lucide-svelte": "^0.476.0",
    "quaternion": "^2.2.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "svelte-leafletjs": "^2.0.0",
    "tauri-plugin-hillview-api": "file:./tauri-plugin-hillview",
    "tsgeo": "^1.2.2",
    "typescript": "^5.7.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  },
  "private": true,
  "scripts": {
    "dev": "vite dev --port ${VITE_DEV_PORT:-8212}",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest --coverage",
    "test:playwright": "cd tests-playwright && bun run test",
    "test:playwright:ui": "cd tests-playwright && bun run test:ui",
    "test:playwright:debug": "cd tests-playwright && bun run test:debug",
    "test:playwright:headed": "cd tests-playwright && bun run test:headed",
    "screenshots": "cd tests-playwright && bun run screenshots",
    "screenshots:desktop": "cd tests-playwright && bun run screenshots:desktop",
    "screenshots:mobile": "cd tests-playwright && bun run screenshots:mobile",
    "test:appium": "./scripts/android/test.sh",
    "test:appium:fast": "./scripts/android/test.sh --fast",
    "test:appium:test0": "./scripts/android/test.sh --spec android-photo-simple.test0.ts",
    "test:appium:import": "./scripts/android/test.sh --spec android-photo-import.test.ts",
    "android:dev": "./scripts/android/dev.sh",
    "android:debug:init": "./scripts/android/debug-init.sh",
    "android:debug:build": "./scripts/android/debug-build.sh",
    "android:debug:install": "./scripts/android/debug-install.sh",
    "android:release:init": "./scripts/android/release-init.sh",
    "android:release:build": "./scripts/android/release-build.sh",
    "android:release:install": "./scripts/android/release-install.sh",
    "android:logs": "./scripts/android/logs.sh",
    "validate": "./scripts/validate.sh",
    "validate:quick": "./scripts/validate.sh --skip-android",
    "validate:android": "./scripts/validate-android.sh",
    "build:check": "./scripts/build-check.sh",
    "clean:android": "./scripts/clean-android.sh",
    "setup:hooks": "./scripts/setup-hooks.sh",
    "ci": "bun run validate",
    "precommit": "bun run validate:quick"
  },
  "type": "module",
  "overrides": {
    "vite": "^6.4.2",
    "rollup": "^4.60.1",
    "yaml": "^2.8.3",
    "picomatch": "^4.0.4"
  },
  "dependencies": {
    "@annotorious/openseadragon": "^3.7.20",
    "@lucide/svelte": "^0.577.0",
    "leaflet-textpath": "^1.3.0",
    "openseadragon": "^6.0.1",
    "qrcode": "^1.5.4"
  },
  "trustedDependencies": []
}
