VITE_FEATURE_USER_ACCOUNTS=true
ANDROID_HOME=/home/user/Android/Sdk
VITE_BACKEND=http://localhost:8055/api

# Server-side URL used during SSR to reach the api.
# Bridge mode: http://api:8055/api   Host mode / dev: http://localhost:8055/api
BACKEND_INTERNAL_URL=http://localhost:8055/api

# Umami Analytics (set VITE_UMAMI_WEBSITE_ID after creating a website in Umami dashboard at localhost:3333)
VITE_UMAMI_WEBSITE_ID=
VITE_UMAMI_URL=http://localhost:3344
