<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools">


    <!-- Required for background uploads -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Required for camera access -->
    <uses-permission android:name="android.permission.CAMERA" />

	<!-- bad -->
	<!--    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />-->


    <!-- Required for accessing photos -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <!-- For Android 13+ (API 33+) - Granular media permissions -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />

    <!-- Required for precise location services -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Required for notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
<!--    <uses-permission android:name="android.permission.VIBRATE" />-->

    <!-- WorkManager 2.9.x declares FOREGROUND_SERVICE itself; the DATA_SYNC
         subtype permission (and a typed foregroundServiceType on the hosting
         SystemForegroundService — see <service> override below) is only
         bundled in 2.10+, which requires compileSdk 35. We declare both here
         so PhotoUploadWorker's typed ForegroundInfo can start the foreground
         upload notification on targetSdk 34+. Both are normal-protection,
         auto-granted, not on Play's sensitive list.
         Drop these when the project moves to compileSdk 35 + WorkManager 2.10+. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />


    <application>
        <!-- Add foregroundServiceType to WorkManager's SystemForegroundService.
             WorkManager 2.9.x declares the <service> without any type; on
             targetSdk 34+ the runtime refuses a typed ForegroundInfo against
             a typeless service ("foregroundServiceType 0x1 is not a subset
             of 0x0"). tools:node="merge" tells the manifest-merger to combine
             this entry with WorkManager's upstream declaration, adding the
             attribute without replacing anything else.
             Drop this once on compileSdk 35 + WorkManager 2.10+. -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!-- Deep link intent filters are added directly to MainActivity by Tauri's deep-link plugin -->

        <!-- FCM notification action handling for MainActivity -->
<!--        <activity android:name="cz.hillview.plugin.CustomMainActivity"-->
<!--				  android:exported="false">-->
<!--            <intent-filter>-->
<!--                <action android:name="VIEW_RECENT_ACTIVITY" />-->
<!--                <category android:name="android.intent.category.DEFAULT" />-->
<!--            </intent-filter>-->
<!--        </activity>-->

		<!-- Notification actions are handled by MainActivity through ExamplePlugin.onNewIntent() -->

		<service android:name="cz.hillview.plugin.PushServiceImpl"
			android:exported="false">
			<intent-filter>
				<action android:name="org.unifiedpush.android.connector.PUSH_EVENT"/>
			</intent-filter>
		</service>

        <!-- Firebase Cloud Messaging service for direct FCM support -->
        <service
            android:name="cz.hillview.plugin.FcmDirectService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>
