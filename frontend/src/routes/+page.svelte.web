<script lang="ts">
	export let data;

	let Main: any;
	if (browser && typeof window !== 'undefined') {
		async function loadMain() {
			console.log('Loading Main component dynamically');
			const module = await import('$lib/components/Main.svelte');
			Main = module.default;
		}
		loadMain();
	}

	import {browser} from '$app/environment';
	import {page} from '$app/stores';
	import {HILLVIEW_BASE_URL} from '$lib/urlUtilsServer';
	import PhotoHead from '$lib/components/PhotoHead.svelte';

	$: meta = data?.photoMeta;
	$: photoTitle = meta
		? meta.description
			? `${meta.description} - Hillview`
			: 'Photo on Hillview'
		: null;
</script>


{#if meta && photoTitle}
	<PhotoHead
		title={photoTitle}
		description={meta.description ?? ''}
		ogType="article"
		ogUrl={$page.url.href}
		ogImage={meta.imageUrl
			? { url: meta.imageUrl, width: meta.width, height: meta.height }
			: null}
		latitude={meta.latitude ?? null}
		longitude={meta.longitude ?? null}
		canonicalUrl={meta.photoUid
			? `${HILLVIEW_BASE_URL}/photo/${encodeURIComponent(meta.photoUid)}`
			: null}
	/>
{/if}

<svelte:head>
	{#if !meta}
		<title>Hillview - annotated panoramas</title>
		<meta property="og:title" content="Hillview - annotated panoramas" />
		<meta property="og:description" content="Photos from places where cars can't go" />
		<meta property="og:type" content="website" />
		<meta property="og:image" content={`${HILLVIEW_BASE_URL}/og-card.png`} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Hillview - annotated panoramas" />
		<meta name="twitter:description" content="Photos from places where cars can't go" />
		<meta name="twitter:image" content={`${HILLVIEW_BASE_URL}/og-card.png`} />
	{/if}
</svelte:head>

{#if browser && Main}
	<svelte:component this={Main}/>
{/if}
