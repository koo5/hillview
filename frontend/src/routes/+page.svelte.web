<script lang="ts">
	import { browser } from '$app/environment';
	import { page } from '$app/stores';
	import { HILLVIEW_BASE_URL } from '$lib/urlUtilsServer';
	import PhotoHead from '$lib/components/PhotoHead.svelte';
	import JsonLd from '$lib/components/JsonLd.svelte';
	import {
		buildHeadTitle,
		buildHeadDescription,
		buildPhotoImageJsonLd,
		pickOgImage,
		type PublicPhoto,
		type PhotoAnnotation
	} from '$lib/photoDisplay';

	export let data:
		| { photo?: PublicPhoto | null; annotations?: PhotoAnnotation[] }
		| undefined = undefined;

	let Main: any;
	if (browser && typeof window !== 'undefined') {
		async function loadMain() {
			console.log('Loading Main component dynamically');
			const module = await import('$lib/components/Main.svelte');
			Main = module.default;
		}
		loadMain();
	}

	// When a ?photo= share card was resolved server-side, render the same
	// OpenGraph + JSON-LD head tags as the /photo/[uid] detail route (shared
	// helpers, same PublicPhoto shape). Otherwise fall back to the site card.
	$: photo = data?.photo ?? null;
	$: annotations = data?.annotations ?? [];
	$: ogImage = photo ? pickOgImage(photo) : null;

	// Site-level identity for search engines: Organization (brand + logo, linked
	// to the Play listing via sameAs) and WebSite. Emitted on the homepage — the
	// canonical site root — alongside any per-photo ImageObject share card.
	const siteJsonLd = {
		'@context': 'https://schema.org',
		'@graph': [
			{
				'@type': 'Organization',
				'@id': `${HILLVIEW_BASE_URL}/#organization`,
				name: 'Hillview',
				url: `${HILLVIEW_BASE_URL}/`,
				logo: `${HILLVIEW_BASE_URL}/icons/128x128@2x.png`,
				sameAs: ['https://play.google.com/store/apps/details?id=cz.hillview']
			},
			{
				'@type': 'WebSite',
				'@id': `${HILLVIEW_BASE_URL}/#website`,
				name: 'Hillview',
				url: `${HILLVIEW_BASE_URL}/`,
				description:
					"An open photo map of annotated panoramas and hilltop viewpoints — photos from places where cars can't go.",
				publisher: { '@id': `${HILLVIEW_BASE_URL}/#organization` }
			}
		]
	};
</script>

{#if photo}
	<PhotoHead
		title={buildHeadTitle(photo, annotations)}
		description={buildHeadDescription(photo)}
		ogType="article"
		ogUrl={$page.url.href}
		ogImage={ogImage ? { url: ogImage.url, width: ogImage.width, height: ogImage.height } : null}
		latitude={photo.latitude}
		longitude={photo.longitude}
		canonicalUrl={`${HILLVIEW_BASE_URL}/photo/${encodeURIComponent(photo.uid)}`}
	/>
	<JsonLd data={buildPhotoImageJsonLd(photo, annotations)} />
{:else}
	<PhotoHead
		title="Hillview - annotated panoramas"
		description="An open map of annotated panoramas and hilltop viewpoints — geotagged photos from places where cars can't go, labeled to help you make sense of the view."
		ogType="website"
		ogImage={{ url: `${HILLVIEW_BASE_URL}/og-card.png`, width: 1200, height: 630 }}
		canonicalUrl={`${HILLVIEW_BASE_URL}/`}
	/>
{/if}

<JsonLd data={siteJsonLd} />

{#if browser && Main}
	<svelte:component this={Main} />
{:else}
	<!-- SSR / pre-hydration placeholder: gives crawlers an h1, a topical sentence
	     and internal links, and users a branded loading state instead of a blank
	     viewport. Replaced by the app as soon as Main's dynamic import resolves. -->
	<div class="loading-hero">
		<h1>Hillview — annotated panoramas</h1>
		<p>An open photo map of hilltop views and panoramas from places where cars can't go, labeled to help you make sense of the view.</p>
		<p class="loading-links">
			<a href="/bestof">Browse the best views</a> ·
			<a href="/about">About Hillview</a> ·
			<a href="/download">Get the Android app</a>
		</p>
		<p class="loading-note">Loading map…</p>
	</div>
{/if}

<style>
	.loading-hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		height: 100vh;
		text-align: center;
		padding: 1rem;
		gap: 0.25rem;
	}

	.loading-hero h1 {
		font-size: 1.5rem;
		font-weight: 600;
		color: #1f2937;
		margin: 0;
	}

	.loading-hero p {
		margin: 0;
		color: #6b7280;
		font-size: 0.9rem;
	}

	.loading-hero a {
		color: #3b82f6;
		text-decoration: underline;
	}

	.loading-note {
		font-size: 0.75rem;
		opacity: 0.7;
	}
</style>
